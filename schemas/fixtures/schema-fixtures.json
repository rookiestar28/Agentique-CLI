{
  "distribution-mode.schema.json": {
    "valid": {
      "mode": "package_download",
      "notes": "Prepared for platform upload review."
    },
    "invalid": {
      "missing-required": {},
      "extra-property": {
        "mode": "package_download",
        "unexpected": true
      },
      "boundary": {
        "mode": "direct_execution"
      }
    }
  },
  "output-contract.schema.json": {
    "valid": {
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string"
          }
        }
      },
      "structuredContent": true,
      "unstructuredFallback": "summary",
      "maxOutputBytes": 65536,
      "timeoutMs": 30000,
      "limitHints": {
        "maxItems": 20,
        "maxRequests": 5
      },
      "errorBehavior": "typed-error",
      "redaction": {
        "secrets": true,
        "privateFields": true,
        "notes": "Redact secrets and private projection fields."
      }
    },
    "invalid": {
      "missing-required": {
        "inputSchema": {
          "type": "object"
        }
      },
      "extra-property": {
        "inputSchema": {
          "type": "object"
        },
        "outputSchema": {
          "type": "object"
        },
        "maxOutputBytes": 65536,
        "timeoutMs": 30000,
        "errorBehavior": "typed-error",
        "redaction": {
          "secrets": true,
          "privateFields": true
        },
        "certifiedSafe": true
      },
      "boundary": {
        "inputSchema": {
          "type": "object"
        },
        "outputSchema": {
          "type": "object"
        },
        "unstructuredFallback": "anything",
        "maxOutputBytes": 999999999,
        "timeoutMs": 999999999,
        "errorBehavior": "guaranteed-success",
        "redaction": {
          "secrets": false,
          "privateFields": true
        }
      }
    }
  },
