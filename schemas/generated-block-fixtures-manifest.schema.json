{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/generated-block-fixtures-manifest.schema.json",
  "title": "Agentique Generated Block Fixtures Manifest",
  "$ref": "#/$defs/generatedBlockFixturesManifest",
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.)(?!.*\\\\)[A-Za-z0-9._/-]+$"
    },
    "generatedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "bytes", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "role": { "type": "string", "enum": ["valid-fixture", "invalid-fixture", "projection-snapshot", "manifest"] },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "generatedBlockFixturesManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "generator", "files", "safety"],
      "properties": {
        "contractVersion": { "type": "string", "const": "agentique.generatedBlockFixtures.v1" },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "generatedAt", "noExecution"],
          "properties": {
            "name": { "type": "string", "const": "agentique-block-fixture-generator" },
            "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
            "generatedAt": { "type": "string", "format": "date-time" },
            "noExecution": { "type": "boolean", "const": true }
          }
        },
        "files": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "$ref": "#/$defs/generatedFile" } },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": ["noExecution", "importsRuntimeCode", "executesBlockTests", "referenceExecution"],
          "properties": {
            "noExecution": { "type": "boolean", "const": true },
            "importsRuntimeCode": { "type": "boolean", "const": false },
            "executesBlockTests": { "type": "boolean", "const": false },
            "referenceExecution": { "type": "boolean", "const": false }
          }
        }
      }
    }
  }
}
