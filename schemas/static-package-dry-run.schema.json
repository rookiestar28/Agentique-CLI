{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/static-package-dry-run.schema.json",
  "title": "Agentique Static Package Dry-Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "candidate",
    "package",
    "files",
    "sourceInventory",
    "resourceManifestPreview",
    "safety"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "agentique.staticPackageDryRun.v1"
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "candidateType", "sourceDigest", "disposition"],
      "properties": {
        "candidateId": {
          "type": "string",
          "pattern": "^(skill-source|role-pack):[a-z0-9][a-z0-9-]{2,63}$"
        },
        "candidateType": {
          "type": "string",
          "enum": ["skill-source-package", "role-plugin-pack"]
        },
        "sourceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "disposition": {
          "type": "string",
          "const": "static-review-candidate"
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "packageKind", "resourceName", "deterministicDryRunOnly", "descriptorOnly"],
      "properties": {
        "packageId": {
          "type": "string",
          "pattern": "^(skill-source|role-pack):[a-z0-9][a-z0-9-]{2,63}$"
        },
        "packageKind": {
          "type": "string",
          "enum": ["static-skill-pack", "workflow-skill-pack", "role-plugin-pack", "connector-metadata-pack"]
        },
        "resourceName": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        "deterministicDryRunOnly": {
          "type": "boolean",
          "const": true
        },
        "descriptorOnly": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/fileSummary"
      }
    },
    "sourceInventory": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "licenseExpression"],
        "properties": {
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "role": {
            "type": "string",
            "enum": ["skill-source", "role-skill-source", "plugin-manifest"]
          },
          "licenseExpression": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120
          }
        }
      }
    },
    "resourceManifestPreview": {
      "$ref": "https://schemas.agentique.io/resource-manifest.schema.json"
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noExecution",
        "noInstall",
        "noNetwork",
        "noArchiveCreation",
        "noArchiveExtraction",
        "noUserConfigMutation",
        "noConnectorActivation",
        "noUpload",
        "noPublication",
        "localReviewOnly"
      ],
      "properties": {
        "noExecution": {
          "type": "boolean",
          "const": true
        },
        "noInstall": {
          "type": "boolean",
          "const": true
        },
        "noNetwork": {
          "type": "boolean",
          "const": true
        },
        "noArchiveCreation": {
          "type": "boolean",
          "const": true
        },
        "noArchiveExtraction": {
          "type": "boolean",
          "const": true
        },
        "noUserConfigMutation": {
          "type": "boolean",
          "const": true
        },
        "noConnectorActivation": {
          "type": "boolean",
          "const": true
        },
        "noUpload": {
          "type": "boolean",
          "const": true
        },
        "noPublication": {
          "type": "boolean",
          "const": true
        },
        "localReviewOnly": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "$defs": {
    "fileSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "bytes", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "role": {
          "type": "string",
          "enum": ["upload-candidate-report", "dry-run-manifest", "resource-manifest-preview", "skill-descriptor", "role-pack-descriptor"]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.env(?:/|$))(?!.*(?:^|/)\\.git(?:/|$))(?!.*(?:^|/)\\.cache(?:/|$))(?!.*(?:^|/)node_modules(?:/|$))(?!.*(?:^|/)private(?:/|$))(?!.*\\.\\.)(?!.*[\\\\]).{1,160}$"
    }
  }
}
