{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/public-readback.schema.json",
  "title": "Agentique Public Readback Projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["resourceId", "state", "updatedAt", "platformUrl"],
  "properties": {
    "resourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "state": {
      "type": "string",
      "enum": ["draft", "review_required", "published", "blocked", "unavailable", "stale"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "platformUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://agentique\\.io/"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "internalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "storageUsage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "number" },
              { "type": "integer" },
              { "type": "string" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        },
        {
          "type": "number",
          "minimum": 0
        }
      ]
    },
    "deploymentDate": {
      "type": "string",
      "format": "date-time"
    },
    "tokenCount": {
      "type": "integer",
      "minimum": 0
    },
    "objectType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "storageMode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "platformProjection": {
      "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/platformProjection"
    },
    "desiredState": {
      "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/desiredState"
    },
    "scannerPolicy": {
      "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/scannerPolicy"
    },
    "packageContext": {
      "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/packageContext"
    },
    "reviewEligibility": {
      "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/reviewEligibility"
    },
    "trustPanel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": ["current", "review-required", "blocked", "stale", "unavailable"]
        },
        "messages": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          }
        },
        "versionHistoryUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://agentique\\.io/"
        }
      }
    },
    "versionHistory": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "observedAt", "state"],
        "properties": {
          "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "observedAt": {
            "type": "string",
            "format": "date-time"
          },
          "state": {
            "type": "string",
            "enum": ["current", "stale", "review-required", "blocked", "unavailable"]
          },
          "desiredStateFingerprint": {
            "$ref": "https://schemas.agentique.io/registry-trust.schema.json#/$defs/fingerprint"
          }
        }
      }
    },
    "parserVariant": {
      "$ref": "https://schemas.agentique.io/parser-variant.schema.json#/$defs/parserVariantReadback"
    },
    "agentNative": {
      "$ref": "https://schemas.agentique.io/agent-native.schema.json#/$defs/agentNativeReadback"
    },
    "reportActionState": {
      "type": "string",
      "enum": ["available", "submitted", "rate-limited", "unavailable"]
    }
  }
}
