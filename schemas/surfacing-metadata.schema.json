{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/surfacing-metadata.schema.json",
  "title": "Agentique Public Surfacing Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["taskIntents", "audience", "priority", "contextBudget"],
  "properties": {
    "taskIntents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 48,
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["agent", "human", "developer", "reviewer", "integrator"]
      }
    },
    "priority": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "multipleOf": 0.01
    },
    "recency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lastReviewedAt"],
      "properties": {
        "lastReviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "reviewCadenceDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtimeFamilies": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "pattern": "^[a-z0-9][a-z0-9.+-]*$"
          }
        },
        "protocols": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "pattern": "^[a-z0-9][a-z0-9.+-]*$"
          }
        }
      }
    },
    "contextBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxTokens", "maxBytes"],
      "properties": {
        "maxTokens": {
          "type": "integer",
          "minimum": 128,
          "maximum": 32000
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 262144
        },
        "preferredSummaryBytes": {
          "type": "integer",
          "minimum": 256,
          "maximum": 32768
        }
      }
    },
    "notes": {
      "type": "string",
      "minLength": 12,
      "maxLength": 400
    }
  }
}
