{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/generated-adapter-manifest.schema.json",
  "title": "Agentique Generated Adapter Manifest",
  "$ref": "#/$defs/generatedAdapterManifest",
  "$defs": {
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "reasonCode": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.)(?!.*\\\\)[A-Za-z0-9._/-]+$"
    },
    "generatedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "bytes", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "role": {
          "type": "string",
          "enum": ["descriptor", "command", "manifest", "guidance"]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "sha256": {
          "$ref": "#/$defs/fingerprint"
        }
      }
    },
    "commandMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commandId", "profileId", "mode", "path", "invariantPhrases"],
      "properties": {
        "commandId": {
          "$ref": "#/$defs/identifier"
        },
        "profileId": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "$ref": "#/$defs/reasonCode"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "invariantPhrases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 6,
            "maxLength": 120
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noExecution",
        "installsDependencies",
        "writesUserConfig",
        "trustsLifecycleHooks",
        "networkAccess",
        "referenceExecution"
      ],
      "properties": {
        "noExecution": {
          "type": "boolean",
          "const": true
        },
        "installsDependencies": {
          "type": "boolean",
          "const": false
        },
        "writesUserConfig": {
          "type": "boolean",
          "const": false
        },
        "trustsLifecycleHooks": {
          "type": "boolean",
          "const": false
        },
        "networkAccess": {
          "type": "boolean",
          "const": false
        },
        "referenceExecution": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "generatedAdapterManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "generator",
        "source",
        "target",
        "files",
        "commandMappings",
        "invariantPhrases",
        "safety",
        "drift"
      ],
      "properties": {
        "contractVersion": {
          "type": "string",
          "const": "1.0"
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "generatedAt"],
          "properties": {
            "name": {
              "type": "string",
              "const": "agentique-portable-adapter-generator"
            },
            "version": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["profileId", "sourceDigest", "schemaId"],
          "properties": {
            "profileId": {
              "$ref": "#/$defs/identifier"
            },
            "sourceDigest": {
              "$ref": "#/$defs/fingerprint"
            },
            "schemaId": {
              "type": "string",
              "const": "https://schemas.agentique.io/portable-profile.schema.json"
            }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["targetId", "support", "artifactKind", "noExecution"],
          "properties": {
            "targetId": {
              "type": "string",
              "enum": ["source-package", "codex-skill", "claude-code-skill", "gemini-cli", "opencode", "other"]
            },
            "support": {
              "type": "string",
              "enum": ["instruction-only", "static-commands", "guidance-only"]
            },
            "artifactKind": {
              "type": "string",
              "enum": ["skill", "subagent", "command", "guidance", "metadata", "source-package"]
            },
            "noExecution": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/generatedFile"
          }
        },
        "commandMappings": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/commandMapping"
          }
        },
        "invariantPhrases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 6,
            "maxLength": 120
          }
        },
        "safety": {
          "$ref": "#/$defs/safety"
        },
        "drift": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["current", "stale", "missing", "mismatch", "unchecked"]
            },
            "checkedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
  }
}
