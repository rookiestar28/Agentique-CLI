      "lastReviewedAt": "2026-06-01T00:00:00Z",
      "reviewCadenceDays": 60
    },
    "compatibility": {
      "runtimeFamilies": ["mcp", "json"],
      "protocols": ["https"]
    },
    "contextBudget": {
      "maxTokens": 1400,
      "maxBytes": 12288,
      "preferredSummaryBytes": 1536
    },
    "notes": "Surface this listing when the task needs tool capabilities and output boundaries."
  },
  "permissionRisk": {
    "readOnly": true,
    "destructive": false,
    "idempotent": true,
    "openWorld": true,
    "externalNetwork": true,
    "credentialed": false,
    "approvalRequired": false,
    "dataSensitivity": "public",
    "capabilities": ["read-public-content", "external-network"],
    "reviewNotes": "Descriptive metadata for a public lookup endpoint; no credential use is declared."
  },
