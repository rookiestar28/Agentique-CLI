{
  "name": "agentique",
  "version": "0.2.2",
  "description": "Public companion monorepo for Agentique resource preparation and readback tooling.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "pack:dry-run": "node scripts/package-dry-run.mjs",
    "install:smoke": "node scripts/package-install-smoke.mjs",
    "registry:readback": "node scripts/registry-readback.mjs",
    "release:go-no-go": "node scripts/check-release-go-no-go.mjs",
    "release:check": "node scripts/release-check.mjs .",
    "portability:generate": "node packages/validator/src/cli.mjs portable-generate",
    "portability:drift": "node packages/validator/src/cli.mjs portable-drift",
    "portability:parity": "node packages/validator/src/cli.mjs portable-parity",
    "portability:debt": "node packages/validator/src/cli.mjs debt-ledger",
    "portability:eval": "node packages/validator/src/cli.mjs portable-eval",
    "graph:validate": "node packages/validator/src/cli.mjs bundle-validate",
    "graph:import-plan": "node packages/validator/src/cli.mjs bundle-import-plan",
    "graph:export-plan": "node packages/validator/src/cli.mjs bundle-export-plan",
    "graph:fixtures": "node packages/validator/src/cli.mjs block-fixtures-generate",
    "graph:ledger": "node packages/validator/src/cli.mjs ledger-inspect",
    "graph:artifact": "node packages/validator/src/cli.mjs artifact-scan",
    "graph:api-drift": "node packages/validator/src/cli.mjs api-drift",
    "urls:check": "node scripts/check-public-url-inventory.mjs",
    "validate:starters": "node scripts/validate-starters.mjs",
    "workflow:check": "node scripts/check-workflow-posture.mjs",
    "test": "node --test scripts/tests/*.test.mjs && npm --prefix packages/validator test && npm --prefix packages/action test && npm --prefix packages/readback test && npm --prefix packages/uploader test"
  },
  "engines": {
    "node": ">=20"
  }
}
